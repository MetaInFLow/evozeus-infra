{
  "schema_version": "factor.v0",
  "id": "default.open_loop",
  "name": "open-loop",
  "framework_id": "agent_session_review.v0",
  "stage": "signal_extraction",
  "runtime_profile": "default",
  "default_enabled": true,
  "version": "0.1.0",
  "status": "active",
  "description": "Detects unresolved follow-up, blocked, TODO, or open-loop user turns.",
  "entrypoint": "factor:OpenLoopFactor",
  "inputs": ["session.events", "user_turn.content"],
  "outputs": ["tag", "score", "evidence_ref", "verdict_signal"],
  "permissions": ["read_session_events"],
  "risks": ["may classify explicit follow-up planning as unresolved work"],
  "rollback": "delete this factor folder or disable it in local config",
  "runtime": {
    "mode": "in_process",
    "timeout_ms": 1000
  }
}
